# Base URL of this instance. Local default is plain HTTP — no TLS/mkcert needed.
# Only switch to https://localhost:3000 (and `npm run dev:https`) when using an
# OAuth provider, whose redirect requires https.
NEXTAUTH_URL=http://localhost:3000

# Session encryption secret. Generate with: openssl rand -base64 32
# `npm run setup` fills this in for you.
NEXTAUTH_SECRET=

# Disable Next.js telemetry at both build time and runtime
NEXT_TELEMETRY_DISABLED=1

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# AUTH_PROVIDER selects how users log in:
#   credentials (default) — username/password, no external identity provider.
#                           Set AUTH_USERNAME / AUTH_PASSWORD below.
#   github                 — GitHub OAuth. Create an OAuth app at
#                            https://github.com/settings/developers with callback
#                            http://localhost:3000/api/auth/callback/github, then
#                            set AUTH_CLIENT_ID / AUTH_CLIENT_SECRET.
#   oauth                  — generic OIDC. Point AUTH_ISSUER at any compliant
#                            provider; endpoints are auto-discovered.
AUTH_PROVIDER=credentials

# Login (used when AUTH_PROVIDER=credentials). Both must be non-empty.
AUTH_USERNAME=user
AUTH_PASSWORD=RAGapheneUser

# OAuth client credentials (used when AUTH_PROVIDER=github or oauth).
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=

# Generic OIDC only (AUTH_PROVIDER=oauth). Set the issuer base URL; the
# .well-known/openid-configuration document is fetched automatically. Or set
# AUTH_WELL_KNOWN directly if the discovery URL is non-standard.
AUTH_ISSUER=
AUTH_WELL_KNOWN=
AUTH_PROVIDER_NAME=

# ---------------------------------------------------------------------------
# Local Documents retriever
# ---------------------------------------------------------------------------
LOCAL_INDEX_DIR=./data/indices
LOCAL_INDEX_MAX_DOCUMENTS=10
LOCAL_INDEX_MAX_CHUNKS=500
LOCAL_INDEX_CHUNK_WORDS=512
LOCAL_INDEX_MAX_COLLECTIONS=3
LOCAL_INDEX_TTL_HOURS=168

# ---------------------------------------------------------------------------
# Retriever credentials
# If variables are unset or empty, the connector downgrades to "client" mode
# and the user must supply credentials in the browser.
# ---------------------------------------------------------------------------

# Elasticsearch endpoint (required for server mode)
ES_ENDPOINT=

# Elasticsearch auth — use API key OR username+password (not both)
ES_API_KEY=
ES_USERNAME=
ES_PASSWORD=

# MongoDB
MONGODB_ENDPOINT=
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_DATABASE=

# ---------------------------------------------------------------------------
# Generator credentials
# If a variable is unset or empty, the connector downgrades to "client" mode
# and the user must supply their own API key in the browser.
# ---------------------------------------------------------------------------

# WatsonX.AI (IBM) — both required for server mode
WATSONX_API_KEY=
WATSONX_PROJECT_ID=

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Ollama runs locally — no API key needed (always client mode)
# By default, no-auth connectors (e.g. Ollama) may only connect to loopback
# endpoints (localhost/127.0.0.1). Set to true on a trusted self-hosted install
# to allow pointing them at a remote host. Leave unset/false for public deployments.
ALLOW_REMOTE_LOCAL_CONNECTOR=

# ---------------------------------------------------------------------------
# Python evaluator
# Create a local venv outside the repo root (venv symlinks inside the project
# directory cause a Turbopack build panic):
#   python3 -m venv ~/workbench-venv && ~/workbench-venv/bin/pip install -r scripts/requirements.txt
# Then set this to the venv directory.  Leave empty to use the system python.
# ---------------------------------------------------------------------------
PYTHON_ENVIRONMENT_PATH=
