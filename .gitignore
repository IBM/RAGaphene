# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# Python virtual environment (created by setup.sh or locally)
/ENV

# npm install hash used by setup.sh to skip npm ci when lockfile is unchanged
/.npm-install-hash

# misc
.DS_Store
*.pem

# debug
npm-debug.log*

# local env files — exclude everything except the example template
.env*
!.env.example

# typescript
*.tsbuildinfo
next-env.d.ts

# Security files
keys
/certs

# Runtime data and logs
/data
/logs

#ide
/.idea/

# VSCode files
.vscode

# Local tooling and internal notes (never ship)
.claude/
CLAUDE.md
