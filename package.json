{
  "name": "ragaphene",
  "version": "0.1.0",
  "private": true,
  "description": "RAGaphene — a workbench for building, evaluating, and analyzing RAG systems",
  "author": "IBM",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=10.9.2"
  },
  "scripts": {
    "setup": "node ./scripts/setup.mjs",
    "dev": "next -p 3000",
    "dev:https:server": "next -p 3001",
    "dev:https:proxy": "local-ssl-proxy --key ./keys/localhost-key.pem --cert ./keys/localhost.pem --source 3000 --target 3001",
    "dev:https": "npm-run-all --parallel dev:https:*",
    "build": "next build",
    "start": "next start -p 3000",
    "start:https:server": "cross-env PORT=3001 next start",
    "start:https:proxy": "local-ssl-proxy --key ./keys/localhost-key.pem --cert ./keys/localhost.pem --source 3000 --target 3001",
    "start:https": "npm-run-all --parallel start:https:*",
    "lint": "next lint",
    "lint:style": "stylelint \"**/*.{css,scss}\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "echo 'E2E tests pending implementation'"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@types/pdf-parse": "^1.1.5",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^15.2.0",
    "prepend-file": "^2.0.1",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "stylelint": "^17.2.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@carbon/charts": "^1.27.2",
    "@carbon/charts-react": "^1.27.2",
    "@carbon/colors": "^11.46.0",
    "@carbon/icons-react": "^11.74.0",
    "@carbon/react": "^1.100.0",
    "@carbon/themes": "^11.67.0",
    "@elastic/elasticsearch": "^8.19.1",
    "@google/generative-ai": "^0.24.1",
    "@ibm-cloud/cloudant": "^0.12.15",
    "d3": "^7.9.0",
    "ibm-watson": "^12.2.0",
    "local-ssl-proxy": "^2.0.5",
    "lodash": "^4.17.23",
    "minisearch": "^7.2.0",
    "mongodb": "^7.1.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "npm-run-all": "^4.1.5",
    "ollama": "^0.6.3",
    "openai": "^6.19.0",
    "pdf-parse": "^1.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.0",
    "react-markdown": "^10.1.0",
    "react-split": "^2.0.14",
    "react-use": "^17.6.0",
    "react-wrap-balancer": "^1.1.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  }
}
